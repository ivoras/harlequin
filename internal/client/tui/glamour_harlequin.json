{
  "document": {
    "block_prefix": "\n",
    "block_suffix": "\n",
    "color": "253",
    "margin": 0
  },
  "block_quote": {
    "indent": 1,
    "indent_token": "│ ",
    "color": "245"
  },
  "paragraph": {},
  "list": {
    "level_indent": 2
  },
  "heading": {
    "block_suffix": "\n",
    "color": "79",
    "bold": true
  },
  "h1": {
    "prefix": " ",
    "suffix": " ",
    "color": "253",
    "background_color": "236",
    "bold": true
  },
  "h2": {
    "prefix": "## ",
    "color": "79"
  },
  "h3": {
    "prefix": "### ",
    "color": "79"
  },
  "h4": {
    "prefix": "#### "
  },
  "h5": {
    "prefix": "##### "
  },
  "h6": {
    "prefix": "###### ",
    "color": "245",
    "bold": false
  },
  "text": {},
  "strikethrough": {
    "crossed_out": true
  },
  "emph": {
    "italic": true,
    "color": "245"
  },
  "strong": {
    "bold": true,
    "color": "122"
  },
  "hr": {
    "color": "238",
    "format": "\n────────\n"
  },
  "item": {
    "block_prefix": "• "
  },
  "enumeration": {
    "block_prefix": ". "
  },
  "task": {
    "ticked": "[✓] ",
    "unticked": "[ ] "
  },
  "link": {
    "color": "79",
    "underline": true
  },
  "link_text": {
    "color": "122",
    "bold": true
  },
  "image": {
    "color": "216",
    "underline": true
  },
  "image_text": {
    "color": "245",
    "format": "Image: {{.text}} →"
  },
  "code": {
    "prefix": " ",
    "suffix": " ",
    "color": "122",
    "background_color": "236"
  },
  "code_block": {
    "color": "253",
    "margin": 2,
    "background_color": "236",
    "chroma": {
      "text": { "color": "#dadada" },
      "comment": { "color": "#8a8a8a" },
      "keyword": { "color": "#5fd7af" },
      "literal_string": { "color": "#ffd7af" },
      "name_function": { "color": "#87ffd7" },
      "background": { "background_color": "#303030" }
    }
  },
  "table": {},
  "definition_list": {},
  "definition_term": {},
  "definition_description": {
    "block_prefix": "\n→ "
  },
  "html_block": {},
  "html_span": {}
}
