# Harlequin server secrets. Copy to .env and fill in.
# Environment variables override values in the YAML config.

# Signing key for issued API tokens (use a long random string).
JWT_SECRET=change-me-to-a-long-random-secret

# Master key for encrypting credentials at rest (MCP header secrets and OAuth
# tokens). A 32-byte key, hex (64 chars) or base64. Required only when using
# MCP servers with header/OAuth auth; keep it stable (rotating it makes stored
# credentials undecryptable). Generate one with:
#   openssl rand -hex 32      (or)   openssl rand -base64 32
# HARLEQUIN_SECRET_KEY=

# API key for the chat LLM provider (e.g. OpenRouter). Leave empty for local llama.cpp.
LLM_API_KEY=

# API key for OpenRouter specifically (if used as a provider).
OPENROUTER_API_KEY=

# API key for the dedicated embeddings provider. Leave empty for local.
EMBED_API_KEY=

# SMTP password for sending registration verification codes. The env var name is
# set by email.smtp_password_env in server.yaml (default SMTP_PASSWORD). Leave
# empty to log codes to the console instead of emailing them.
SMTP_PASSWORD=

# Optional: override the SQLite database path (otherwise <data_dir>/harlequin.db).
# HARLEQUIN_DB_PATH=
