# Harlequin server secrets. Copy to .env and fill in.
# Environment variables override values in the YAML config.

# Signing key for issued API tokens (use a long random string).
JWT_SECRET=change-me-to-a-long-random-secret

# API key for the chat LLM provider (e.g. OpenRouter). Leave empty for local llama.cpp.
LLM_API_KEY=

# API key for OpenRouter specifically (if used as a provider).
OPENROUTER_API_KEY=

# API key for the dedicated embeddings provider. Leave empty for local.
EMBED_API_KEY=

# Optional: override the SQLite database path (otherwise <data_dir>/harlequin.db).
# HARLEQUIN_DB_PATH=
